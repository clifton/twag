#!/bin/sh
# commit-msg hook: enforce Conventional Commits format
# Allowed types: feat, fix, docs, chore, refactor, perf, test, ci, security
# Format: type[(scope)][!]: description

commit_msg_file="$1"
commit_msg=$(head -1 "$commit_msg_file")

# Allow merge commits
case "$commit_msg" in
    Merge\ *) exit 0 ;;
esac

# Allow revert commits
case "$commit_msg" in
    Revert\ *) exit 0 ;;
esac

# Allow fixup/squash commits (generated by git commit --fixup/--squash)
case "$commit_msg" in
    fixup!\ *|squash!\ *|amend!\ *) exit 0 ;;
esac

# Validate Conventional Commits format
# type[(scope)][!]: description (description must be non-empty)
if ! echo "$commit_msg" | grep -qE '^(feat|fix|docs|chore|refactor|perf|test|ci|security)(\([a-zA-Z0-9_-]+\))?!?: .+'; then
    echo >&2 ""
    echo >&2 "ERROR: Commit message does not follow Conventional Commits format."
    echo >&2 ""
    echo >&2 "Expected: type[(scope)][!]: description"
    echo >&2 "Types:    feat, fix, docs, chore, refactor, perf, test, ci, security"
    echo >&2 ""
    echo >&2 "Examples:"
    echo >&2 "  feat: add tweet sentiment analysis"
    echo >&2 "  fix(scorer): handle empty responses"
    echo >&2 "  docs: update installation guide"
    echo >&2 "  chore!: drop Python 3.10 support"
    echo >&2 ""
    echo >&2 "Got: $commit_msg"
    echo >&2 ""
    exit 1
fi
